  "dependencies": {
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.7",
    "axios": "^1.6.7",
    "@vueuse/core": "^10.9.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "vite": "^5.2.8",
    "@vitest/ui": "^1.4.0",
    "jsdom": "^24.0.0",
    "vitest": "^1.4.0",
    "@vue/test-utils": "^2.4.5",
    "c8": "^9.1.0",
    "@types/node": "^20.12.7",
    "eslint": "^8.57.0",
    "@rushstack/eslint-patch": "^1.8.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "typescript": "~5.4.0",
    "vue-tsc": "^2.0.14",
    "@vitest/coverage-v8": "^1.4.0"
